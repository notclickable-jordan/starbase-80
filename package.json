{
	"name": "starbase-80",
	"displayName": "Starbase 80",
	"homepage": "https://www.starbase80.dev/",
	"repository": {
		"url": "https://github.com/notclickable-jordan/starbase-80/"
	},
	"version": "1.6.6",
	"type": "commonjs",
	"scripts": {
		"build": "tsc && node ./dist/index.js && npm run html && npm run tailwind && npm run css-cache-break",
		"html": "html-minifier --remove-comments --collapse-whitespace --input-dir ./public --output-dir ./public --file-ext html",
		"tailwind": "npx @tailwindcss/cli -i ./src/tailwind.css -o ./public/main.css --minify",
		"css-cache-break": "node ./dist/css-cache-break.js",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage"
	},
	"dependencies": {
		"@types/node": "^26.1.1",
		"html-minifier": "^4.0.0",
		"prettier": "^3.9.5",
		"prettier-plugin-tailwindcss": "^0.8.1",
		"tailwindcss": "^4.3.2",
		"typescript": "^7.0.2"
	},
	"prettier": {
		"arrowParens": "avoid",
		"jsxBracketSameLine": true,
		"printWidth": 120,
		"semi": true,
		"tabWidth": 4,
		"trailingComma": "es5",
		"useTabs": true,
		"plugins": [
			"prettier-plugin-tailwindcss"
		]
	},
	"devDependencies": {
		"@swc/core": "^1.15.43",
		"@swc/jest": "^0.2.39",
		"@tailwindcss/cli": "^4.3.2",
		"@types/jest": "^30.0.0",
		"jest": "^30.4.2"
	}
}
